generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This table has subclasses and requires additional setup for migrations. Visit https://pris.ly/d/table-inheritance for more info.
model alert {
  id             String    @default(dbgenerated("(gen_random_uuid())::text"))
  timestamp      DateTime  @default(now()) @db.Timestamptz(6)
  farmId         String    @map("farm_id")
  houseId        String    @map("house_id")
  sensorId       String?   @map("sensor_id")
  alertType      String    @map("alert_type")
  severity       String?   @default("WARNING")
  message        String?
  value          Float?
  threshold      Float?
  metadata       Json?     @default("{}")
  acknowledged   Boolean?  @default(false)
  acknowledgedAt DateTime? @map("acknowledged_at") @db.Timestamptz(6)

  @@id([timestamp, id])
  @@index([timestamp(sort: Desc)])
  @@index([farmId, houseId, timestamp(sort: Desc)], map: "idx_alerts_farm_house")
  @@map("alerts")
}

model auditLog {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  farmId     String?  @map("farm_id")
  userId     String?  @map("user_id")
  userName   String?  @map("user_name")
  action     String
  targetType String   @map("target_type")
  targetId   String?  @map("target_id")
  details    Json?    @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([farmId, createdAt(sort: Desc)], map: "idx_audit_logs_farm")
  @@index([createdAt(sort: Desc)], map: "idx_audit_logs_time")
  @@map("audit_logs")
}

model automationRule {
  id               String    @id
  farmId           String    @map("farm_id")
  houseId          String?   @map("house_id")
  name             String
  description      String    @default("")
  enabled          Boolean   @default(true)
  conditionLogic   String    @default("AND") @map("condition_logic")
  conditions       Json
  actions          Json
  cooldownSeconds  Int       @default(300) @map("cooldown_seconds")
  lastTriggeredAt  DateTime? @map("last_triggered_at")
  triggerCount     Int       @default(0) @map("trigger_count")
  priority         Int       @default(10)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  groupLogic       String    @default("AND") @map("group_logic")

  @@index([farmId, houseId, enabled])
  @@map("automation_rules")
}

model businessProject {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  farms     farm[]

  @@map("business_projects")
}

/// This table has subclasses and requires additional setup for migrations. Visit https://pris.ly/d/table-inheritance for more info.
model controlLog {
  id               String   @default(dbgenerated("(gen_random_uuid())::text"))
  timestamp        DateTime @default(now()) @db.Timestamptz(6)
  farmId           String   @map("farm_id")
  houseId          String   @map("house_id")
  controlHouseId   String?  @map("control_house_id")
  deviceId         String   @map("device_id")
  deviceType       String?  @default("unknown") @map("device_type")
  deviceName       String?  @map("device_name")
  command          String
  success          Boolean  @default(true)
  error            String?
  requestId        String?  @map("request_id")
  operator         String?  @default("web_dashboard")
  operatorName     String?  @map("operator_name")
  lambdaResponse   Json?    @map("lambda_response")
  isAutomatic      Boolean? @default(false) @map("is_automatic")
  automationRuleId String?  @map("automation_rule_id")
  automationReason String?  @map("automation_reason")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@id([timestamp, id])
  @@index([timestamp(sort: Desc)])
  @@index([farmId, deviceId, timestamp(sort: Desc)], map: "idx_control_logs_farm_device")
  @@index([farmId, houseId, timestamp(sort: Desc)], map: "idx_control_logs_farm_house")
  @@index([requestId], map: "idx_control_logs_request_id")
  @@map("control_logs")
}

model farmDocument {
  id           String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  farmId       String   @map("farm_id")
  fileName     String   @map("file_name")
  originalName String   @map("original_name")
  filePath     String   @map("file_path")
  fileSize     Int      @default(0) @map("file_size")
  mimeType     String?  @map("mime_type")
  category     String   @default("other")
  description  String?
  uploadedBy   String?  @map("uploaded_by")
  uploaderId   String?  @map("uploader_id")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  farm         farm     @relation(fields: [farmId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([farmId, createdAt(sort: Desc)], map: "idx_farm_documents_created")
  @@index([farmId, category], map: "idx_farm_documents_farm")
  @@map("farm_documents")
}

model farmJournal {
  id          String   @id
  farmId      String   @map("farm_id")
  houseId     String?  @map("house_id")
  date        DateTime @db.Date
  weather     String?
  tempMin     Float?   @map("temp_min")
  tempMax     Float?   @map("temp_max")
  humidity    Float?
  workType    String   @map("work_type")
  growthStage String?  @map("growth_stage")
  content     String
  pest        String?
  notes       String?
  photos      Json     @default("[]")
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([farmId, date])
  @@index([farmId, houseId, date])
  @@map("farm_journals")
}

model farmNote {
  id        String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  farmId    String    @map("farm_id")
  content   String
  author    String?
  authorId  String?   @map("author_id")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  farm      farm      @relation(fields: [farmId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([farmId, createdAt(sort: Desc)], map: "idx_farm_notes_farm_created")
  @@map("farm_notes")
}

model farmSchedule {
  id          String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  farmId      String    @map("farm_id")
  title       String
  description String?
  type        String    @default("general")
  startDate   DateTime  @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  allDay      Boolean   @default(true) @map("all_day")
  completed   Boolean   @default(false)
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)
  assignedTo  String?   @map("assigned_to")
  houseId     String?   @map("house_id")
  priority    String    @default("normal")
  color       String?
  recurrence  Json?
  createdBy   String?   @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  farm        farm      @relation(fields: [farmId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([farmId, completed, startDate], map: "idx_farm_schedules_completed")
  @@index([farmId, startDate], map: "idx_farm_schedules_farm_date")
  @@map("farm_schedules")
}

model farm {
  id                  String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  farmId              String            @unique @map("farm_id")
  name                String
  location            String?
  ownerName           String?           @map("owner_name")
  ownerPhone          String?           @map("owner_phone")
  apiKey              String            @unique @map("api_key")
  status              String?           @default("active")
  lastSeenAt          DateTime?         @map("last_seen_at") @db.Timestamptz(6)
  memo                String?
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @default(now()) @map("updated_at")
  managers            Json?             @default("[]")
  registeredAt        DateTime?         @default(dbgenerated("CURRENT_DATE")) @map("registered_at") @db.Date
  maintenanceMonths   Int?              @default(12) @map("maintenance_months")
  maintenanceStartAt  DateTime?         @default(dbgenerated("CURRENT_DATE")) @map("maintenance_start_at") @db.Date
  systemType          String?           @map("system_type")
  farmType            String?           @map("farm_type")
  farmArea            String?           @map("farm_area")
  tags                String[]          @default([])
  deletedAt           DateTime?         @map("deleted_at") @db.Timestamptz(6)
  businessProjectId   String?           @map("business_project_id")
  totalCost           BigInt?           @map("total_cost")
  subsidyAmount       BigInt?           @map("subsidy_amount")
  selfFunding         BigInt?           @map("self_funding")
  businessType        String?           @map("business_type")
  farmDocuments       farmDocument[]
  farmNotes           farmNote[]
  farmSchedules       farmSchedule[]
  businessProject     businessProject?  @relation(fields: [businessProjectId], references: [id], onUpdate: NoAction)
  maintenanceLogs     maintenanceLog[]
  userFarms           userFarm[]

  @@map("farms")
}

model harvestRecord {
  id           String   @id
  farmId       String   @map("farm_id")
  houseId      String?  @map("house_id")
  date         DateTime @db.Date
  cropName     String   @map("crop_name")
  quantity     Float
  unit         String   @default("kg")
  grade        String?
  destination  String?
  unitPrice    Float?   @map("unit_price")
  totalRevenue Float?   @map("total_revenue")
  notes        String?
  photos       Json     @default("[]")
  createdBy    String   @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([farmId, date])
  @@map("harvest_records")
}

model houseConfig {
  id            String   @id
  farmId        String   @map("farm_id")
  houseId       String   @map("house_id")
  houseName     String   @default("") @map("house_name")
  sensors       Json     @default("[]")
  collection    Json     @default("{}")
  devices       Json     @default("[]")
  deviceCount   Int      @default(0) @map("device_count")
  enabled       Boolean  @default(true)
  configVersion Int      @default(1) @map("config_version")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  crops         Json     @default("[]")
  cropType      String   @default("") @map("crop_type")
  cropVariety   String   @default("") @map("crop_variety")
  plantingDate  String   @default("") @map("planting_date")

  @@unique([farmId, houseId])
  @@map("house_configs")
}

model inputRecord {
  id           String   @id
  farmId       String   @map("farm_id")
  houseId      String?  @map("house_id")
  date         DateTime @db.Date
  inputType    String   @map("input_type")
  productName  String   @map("product_name")
  manufacturer String?
  quantity     Float
  unit         String
  cost         Float?
  targetArea   Float?   @map("target_area")
  method       String?
  notes        String?
  createdBy    String   @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([farmId, date])
  @@map("input_records")
}

model maintenanceLog {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  farmId      String   @map("farm_id")
  date        DateTime @db.Date
  type        String
  title       String
  description String?
  cost        Int?
  technician  String?
  status      String   @default("completed")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")
  farm        farm     @relation(fields: [farmId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([farmId, date], map: "idx_maintenance_logs_farm_date")
  @@map("maintenance_logs")
}

/// This table has subclasses and requires additional setup for migrations. Visit https://pris.ly/d/table-inheritance for more info.
model sensorData {
  timestamp DateTime @db.Timestamptz(6)
  farmId    String   @map("farm_id")
  houseId   String   @map("house_id")
  data      Json     @default("{}")
  metadata  Json?    @default("{}")

  @@id([timestamp, farmId, houseId])
  @@index([farmId, houseId, timestamp(sort: Desc)], map: "idx_sensor_data_farm_house")
  @@index([timestamp(sort: Desc)])
  @@map("sensor_data")
}

model systemSetting {
  farmId    String   @id @map("farm_id")
  settings  Json     @default("{}")
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("system_settings")
}

model userFarm {
  id          String  @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId      String  @map("user_id")
  farmId      String  @map("farm_id")
  role        String? @default("viewer")
  permissions Json    @default("{}")
  farm        farm    @relation(fields: [farmId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user        user    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, farmId])
  @@map("user_farms")
}

model user {
  id            String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  username      String     @unique
  password      String
  name          String
  role          String     @default("worker")
  farmId        String     @default("farm_0001") @map("farm_id")
  allowedHouses String[]   @default([]) @map("allowed_houses")
  enabled       Boolean    @default(true)
  lastLoginAt   DateTime?  @map("last_login_at")
  refreshToken  String?    @map("refresh_token")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  userFarms     userFarm[]

  @@map("users")
}
